def init_state():
"""최초 실행 시 기본값 설정"""
defaults = {
"step": "start", # start | name | question | result
"cat": None, # A / B / C
"name": "", # 사용자 이름
"q_idx": 0, # 현재 질문 번호 (0~3)
"answers": [], # [(선택 인덱스, 차원), ...]
"mbti": None, # 계산된 MBTI
"fairy_job": "", # magic_data 동화 직업
"real_job": "", # magic_data 현실 직업
"prophecy": "", # magic_data 예언 문구
}
for k, v in defaults.items():
if k not in st.session_state:
st.session_state[k] = v

def reset_state():
"""다시하기: 전체 session_state 초기화"""
for k in list(st.session_state.keys()):
del st.session_state[k]
init_state()

init_state()


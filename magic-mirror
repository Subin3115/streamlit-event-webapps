# ═══════════════════════════════════════════════════════════
elif st.session_state.step == "result":
cat = st.session_state.cat
mbti = st.session_state.mbti
name = st.session_state.name
fairy_job = st.session_state.fairy_job
real_job = st.session_state.real_job
prophecy = st.session_state.prophecy

st.balloons()
st.title("✨ 운명의 예언서")
st.write(f"**{name}** 님의 진로 추천 결과입니다")

# ── 계열 이미지 출력 (파일 없으면 이모지 대체)
try:
img_map = {"A": "tarot1.jpg", "B": "tarot2.jpg", "C": "tarot3.jpg"}
c1, c2, c3 = st.columns([1, 2, 1])
with c2:
st.image(img_map[cat], use_container_width=True,
caption=CAT_INFO[cat]["label"])
except Exception:
st.write(CAT_INFO[cat]["emoji"])

st.divider()

# ── MBTI 결과
st.subheader(f"나의 MBTI 유형: {mbti}")
st.write(f"선택 계열: **{CAT_INFO[cat]['label']}**")

st.divider()

# ── 직업 추천 결과
st.success(f"✨ {name} 님의 운명적 예언")
st.subheader(f"🏰 동화 속 당신은: [{fairy_job}]")
st.write(f"💼 현실에서의 모습은: **{real_job}**")

# ── 마법 거울 예언 문구
st.info(
f"📜 마법 거울의 한마디:\n\n"
f"'{name}'아, {prophecy}\n\n"
f"지금의 그 마음을 잃지 않는다면 현실에서도 멋진 **{real_job}**이 될 것이로다!"
)

st.divider()


# ── 다시하기 버튼 → session_state 전체 초기화
